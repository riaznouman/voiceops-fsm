DATABASE_URL="postgresql://user:password@localhost:5432/voiceops"
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Gmail SMTP for sending verification / password-reset emails
# Generate an App Password at https://myaccount.google.com/apppasswords (2FA must be on)
GMAIL_ADDRESS="your-sender@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Vapi.ai voice receptionist
# Get these from your Vapi dashboard: https://dashboard.vapi.ai
# VAPI_API_KEY        — server-side API key for calling Vapi (outbound calls / assistant updates)
# VAPI_ASSISTANT_ID   — id of the configured assistant that answers your phone number
# VAPI_PHONE_NUMBER_ID — id of the phone number in Vapi (the one customers dial)
# VAPI_WEBHOOK_SECRET — shared secret Vapi signs webhook payloads with (HMAC SHA-256)
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=changeme
