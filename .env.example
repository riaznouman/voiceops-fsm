DATABASE_URL="postgresql://user:password@localhost:5432/voiceops"
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Gmail SMTP for sending verification / password-reset emails
# Generate an App Password at https://myaccount.google.com/apppasswords (2FA must be on)
GMAIL_ADDRESS="your-sender@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Vapi.ai voice receptionist
# Get these from your Vapi dashboard: https://dashboard.vapi.ai
# VAPI_API_KEY         — server-side (private) API key for calling Vapi
# VAPI_PUBLIC_KEY      — public key used by client-side voice widgets (optional)
# VAPI_ASSISTANT_ID    — id of the configured assistant that answers calls
# VAPI_PHONE_NUMBER_ID — id of the phone number in Vapi (the one customers dial)
# VAPI_WEBHOOK_TOKEN   — bearer token Vapi sends in the Authorization header for webhook calls
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_TOKEN=changeme
